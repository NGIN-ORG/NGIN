{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "NGIN Workspace Dev",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/dev",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "NGIN_WORKSPACE_ENABLE_INTEGRATION": "ON",
        "NGIN_WORKSPACE_EXPECT_COMPONENTS": "OFF"
      }
    },
    {
      "name": "strict",
      "displayName": "NGIN Workspace Strict (Expect Components)",
      "inherits": "dev",
      "binaryDir": "${sourceDir}/build/strict",
      "cacheVariables": {
        "NGIN_WORKSPACE_EXPECT_COMPONENTS": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "NGIN CLI Release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "BUILD_TESTING": "OFF",
        "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded",
        "NGIN_WORKSPACE_ENABLE_INTEGRATION": "OFF",
        "NGIN_CLI_PORTABLE_RUNTIME": "ON",
        "NGIN_CLI_BUNDLE_BUILD_TOOLS": "OFF"
      }
    },
    {
      "name": "release-bundled",
      "displayName": "NGIN CLI Release With Bundled Build Tools",
      "inherits": "release",
      "binaryDir": "${sourceDir}/build/release-bundled",
      "cacheVariables": {
        "NGIN_CLI_BUNDLE_BUILD_TOOLS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "targets": [
        "ngin.workflow"
      ]
    },
    {
      "name": "release",
      "configurePreset": "release",
      "targets": ["ngin_cli"]
    },
    {
      "name": "release-bundled",
      "configurePreset": "release-bundled",
      "targets": ["ngin_cli"]
    }
  ]
}
