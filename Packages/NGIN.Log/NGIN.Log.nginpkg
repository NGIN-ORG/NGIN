<?xml version="1.0" encoding="utf-8"?>
<Package SchemaVersion="1"
         Name="NGIN.Log"
         Version="0.1.0"
         CompatiblePlatformRange=">=0.1.0-alpha.1 &lt;0.2.0">
  <SourceBinding Kind="Source" Path="Dependencies/NGIN/NGIN.Log" />
  <Artifacts>
    <Libraries>
      <Library Name="NGIN.Log" Target="NGIN::Log" Linkage="Static" />
    </Libraries>
  </Artifacts>
  <Build Backend="CMake" Mode="AddSubdirectory">
    <Options>
      <Option Name="NGIN_LOG_BUILD_TESTS" Value="OFF" />
      <Option Name="NGIN_LOG_BUILD_EXAMPLES" Value="OFF" />
      <Option Name="NGIN_LOG_BUILD_BENCHMARKS" Value="OFF" />
    </Options>
  </Build>
  <Platforms>
    <Platform Name="linux" />
    <Platform Name="windows" />
    <Platform Name="macos" />
  </Platforms>
  <Dependencies>
    <Dependency Name="NGIN.Base" VersionRange=">=0.1.0 &lt;0.2.0" Optional="false" />
  </Dependencies>
  <Modules>
    <Module Name="Log.Foundation"
            Family="Core"
            Type="Runtime"
            LoadPhase="Bootstrap"
            Version="0.1.0"
            CompatiblePlatformRange=">=0.1.0-alpha.1 &lt;0.2.0"
            ReflectionRequired="false">
      <Platforms>
        <Platform Name="linux" />
        <Platform Name="windows" />
        <Platform Name="macos" />
      </Platforms>
      <Dependencies>
        <Dependency Name="Base.Foundation" Optional="false" />
      </Dependencies>
      <ProvidesServices />
      <RequiresServices />
      <Capabilities />
    </Module>
  </Modules>
  <Plugins />
</Package>
