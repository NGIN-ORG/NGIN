{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ngin.dev/schemas/ngin-composition-graph-v4.schema.json",
  "title": "NGIN Composition Graph V4 JSON Contract",
  "description": "Stable V4 Composition Graph and focused plan JSON envelopes emitted by ngin inspect and ngin graph.",
  "oneOf": [
    { "$ref": "#/$defs/compositionGraph" },
    { "$ref": "#/$defs/compositionGraphPlan" }
  ],
  "$defs": {
    "stringArray": {
      "type": "array",
      "items": { "type": "string" }
    },
    "provenance": {
      "type": "object",
      "required": ["sourceKind", "sourceName", "manifestPath", "reason"],
      "properties": {
        "sourceKind": {
          "type": "string",
          "enum": [
            "convention",
            "project",
            "project-profile",
            "workspace-profile",
            "workspace-product-profile",
            "package",
            "package-feature"
          ]
        },
        "sourceName": { "type": "string" },
        "manifestPath": { "type": "string" },
        "reason": { "type": "string" }
      },
      "additionalProperties": true
    },
    "diagnostic": {
      "type": "object",
      "required": ["severity", "subject", "message"],
      "properties": {
        "severity": { "type": "string", "enum": ["error", "warning"] },
        "subject": { "type": "string" },
        "message": { "type": "string" }
      },
      "additionalProperties": true
    },
    "identity": {
      "type": "object",
      "required": ["project", "projectPath", "product", "profile", "version"],
      "properties": {
        "project": { "type": "string" },
        "projectPath": { "type": "string" },
        "product": { "type": "string" },
        "profile": { "type": "string" },
        "version": { "type": "string" }
      },
      "additionalProperties": true
    },
    "planIdentity": {
      "type": "object",
      "required": ["project", "product", "profile", "version"],
      "properties": {
        "project": { "type": "string" },
        "product": { "type": "string" },
        "profile": { "type": "string" },
        "version": { "type": "string" }
      },
      "additionalProperties": true
    },
    "product": {
      "type": "object",
      "required": ["kind", "outputType", "outputName", "targetName"],
      "properties": {
        "kind": { "type": "string" },
        "outputType": { "type": "string" },
        "outputName": { "type": "string" },
        "targetName": { "type": "string" }
      },
      "additionalProperties": true
    },
    "selection": {
      "type": "object",
      "required": [
        "profile",
        "hostPlatform",
        "targetPlatform",
        "operatingSystem",
        "architecture",
        "toolchain",
        "environment",
        "abiTag"
      ],
      "properties": {
        "profile": { "type": "string" },
        "hostPlatform": { "type": "string" },
        "targetPlatform": { "type": "string" },
        "operatingSystem": { "type": "string" },
        "architecture": { "type": "string" },
        "toolchain": { "type": "string" },
        "environment": { "type": "string" },
        "abiTag": { "type": "string" }
      },
      "additionalProperties": true
    },
    "convention": {
      "type": "object",
      "required": ["name", "reason", "provenance"],
      "properties": {
        "name": { "type": "string" },
        "reason": { "type": "string" },
        "provenance": { "$ref": "#/$defs/provenance" }
      },
      "additionalProperties": true
    },
    "property": {
      "type": "object",
      "required": ["name", "value", "provenance"],
      "properties": {
        "name": { "type": "string" },
        "value": {
          "type": "string",
          "description": "Secret values are emitted as the literal <redacted>."
        },
        "provenance": { "$ref": "#/$defs/provenance" }
      },
      "additionalProperties": true
    },
    "facetsSummary": {
      "type": "object",
      "required": [
        "packages",
        "packageFeatures",
        "sources",
        "headers",
        "generators",
        "stagedFiles",
        "runtimeModules",
        "environmentVariables",
        "publishes",
        "toolRuns",
        "diagnostics"
      ],
      "properties": {
        "packages": { "type": "integer", "minimum": 0 },
        "packageFeatures": { "type": "integer", "minimum": 0 },
        "sources": { "type": "integer", "minimum": 0 },
        "headers": { "type": "integer", "minimum": 0 },
        "generators": { "type": "integer", "minimum": 0 },
        "stagedFiles": { "type": "integer", "minimum": 0 },
        "runtimeModules": { "type": "integer", "minimum": 0 },
        "environmentVariables": { "type": "integer", "minimum": 0 },
        "publishes": { "type": "integer", "minimum": 0 },
        "toolRuns": { "type": "integer", "minimum": 0 },
        "diagnostics": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": true
    },
    "package": {
      "type": "object",
      "required": [
        "name",
        "version",
        "source",
        "provider",
        "providerKind",
        "providerPackage",
        "providerVersion",
        "providerRoot",
        "scope",
        "closures",
        "dependencies"
      ],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "source": { "type": "string" },
        "provider": { "type": "string" },
        "providerKind": { "type": "string" },
        "providerPackage": { "type": "string" },
        "providerVersion": { "type": "string" },
        "providerRoot": { "type": "string" },
        "scope": { "type": "string" },
        "closures": { "$ref": "#/$defs/stringArray" },
        "dependencies": { "$ref": "#/$defs/stringArray" },
        "provenance": { "$ref": "#/$defs/provenance" }
      },
      "additionalProperties": true
    },
    "packageFeature": {
      "type": "object",
      "required": ["package", "feature", "packageVersion"],
      "properties": {
        "package": { "type": "string" },
        "feature": { "type": "string" },
        "packageVersion": { "type": "string" },
        "provenance": { "$ref": "#/$defs/provenance" }
      },
      "additionalProperties": true
    },
    "buildDefine": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["value", "provenance"],
          "properties": {
            "value": { "type": "string" },
            "provenance": { "$ref": "#/$defs/provenance" }
          },
          "additionalProperties": true
        }
      ]
    },
    "buildInput": {
      "type": "object",
      "required": ["kind", "role", "source", "owner"],
      "properties": {
        "kind": { "type": "string" },
        "role": { "type": "string" },
        "source": { "type": "string" },
        "owner": { "type": "string" },
        "provenance": { "$ref": "#/$defs/provenance" }
      },
      "additionalProperties": true
    },
    "buildPlan": {
      "type": "object",
      "required": ["defines", "inputs"],
      "properties": {
        "defines": {
          "type": "array",
          "items": { "$ref": "#/$defs/buildDefine" }
        },
        "inputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/buildInput" }
        }
      },
      "additionalProperties": true
    },
    "generator": {
      "type": "object",
      "required": ["name", "owner", "tool", "outputs"],
      "properties": {
        "name": { "type": "string" },
        "owner": { "type": "string" },
        "tool": { "type": "string" },
        "outputs": { "type": "integer", "minimum": 0 },
        "provenance": { "$ref": "#/$defs/provenance" }
      },
      "additionalProperties": true
    },
    "stageFile": {
      "type": "object",
      "required": ["kind", "source", "target", "owner"],
      "properties": {
        "kind": { "type": "string" },
        "source": { "type": "string" },
        "target": { "type": "string" },
        "owner": { "type": "string" },
        "provenance": { "$ref": "#/$defs/provenance" }
      },
      "additionalProperties": true
    },
    "stagePlan": {
      "type": "object",
      "required": ["files"],
      "properties": {
        "files": {
          "type": "array",
          "items": { "$ref": "#/$defs/stageFile" }
        }
      },
      "additionalProperties": true
    },
    "runtimeModule": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["name", "provenance"],
          "properties": {
            "name": { "type": "string" },
            "provenance": { "$ref": "#/$defs/provenance" }
          },
          "additionalProperties": true
        }
      ]
    },
    "runtimePlugin": {
      "oneOf": [
        { "type": "string" },
        {
          "type": "object",
          "required": ["name", "provenance"],
          "properties": {
            "name": { "type": "string" },
            "provenance": { "$ref": "#/$defs/provenance" }
          },
          "additionalProperties": true
        }
      ]
    },
    "runtimePlan": {
      "type": "object",
      "required": ["requiredModules", "optionalModules", "plugins"],
      "properties": {
        "requiredModules": {
          "type": "array",
          "items": { "$ref": "#/$defs/runtimeModule" }
        },
        "optionalModules": {
          "type": "array",
          "items": { "$ref": "#/$defs/runtimeModule" }
        },
        "plugins": {
          "type": "array",
          "items": { "$ref": "#/$defs/runtimePlugin" }
        }
      },
      "additionalProperties": true
    },
    "environmentVariable": {
      "type": "object",
      "required": ["name", "value", "secret", "resolved", "source"],
      "properties": {
        "name": { "type": "string" },
        "value": { "type": "string" },
        "secret": { "type": "boolean" },
        "resolved": { "type": "boolean" },
        "source": { "type": "string" },
        "provenance": { "$ref": "#/$defs/provenance" }
      },
      "additionalProperties": true
    },
    "environmentPlan": {
      "type": "object",
      "required": ["variables"],
      "properties": {
        "variables": {
          "type": "array",
          "items": { "$ref": "#/$defs/environmentVariable" }
        }
      },
      "additionalProperties": true
    },
    "launch": {
      "type": "object",
      "required": ["name", "executable", "workingDirectory", "args", "selected"],
      "properties": {
        "name": { "type": "string" },
        "executable": { "type": "string" },
        "workingDirectory": { "type": "string" },
        "args": { "type": "string" },
        "selected": { "type": "boolean" },
        "provenance": { "$ref": "#/$defs/provenance" }
      },
      "additionalProperties": true
    },
    "packageOutput": {
      "type": "object",
      "required": ["name", "version", "from", "headers", "libraries", "tools", "capabilities", "abi"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "from": { "type": "string" },
        "headers": { "type": "integer", "minimum": 0 },
        "libraries": { "type": "integer", "minimum": 0 },
        "tools": { "type": "integer", "minimum": 0 },
        "capabilities": { "type": "integer", "minimum": 0 },
        "abi": { "type": "string" },
        "provenance": { "$ref": "#/$defs/provenance" }
      },
      "additionalProperties": true
    },
    "publish": {
      "type": "object",
      "required": [
        "name",
        "kind",
        "format",
        "output",
        "includeStage",
        "includeRuntimeDependencies",
        "includeSymbols",
        "installer"
      ],
      "properties": {
        "name": { "type": "string" },
        "kind": { "type": "string" },
        "format": { "type": "string" },
        "output": { "type": "string" },
        "includeStage": { "type": "boolean" },
        "includeRuntimeDependencies": { "type": "boolean" },
        "includeSymbols": { "type": "boolean" },
        "installer": {
          "type": "object",
          "required": ["identifier", "vendor", "contact", "scope", "addToPath"],
          "properties": {
            "identifier": { "type": "string" },
            "vendor": { "type": "string" },
            "contact": { "type": "string" },
            "scope": { "type": "string" },
            "addToPath": { "type": "boolean" }
          },
          "additionalProperties": true
        },
        "provenance": { "$ref": "#/$defs/provenance" }
      },
      "additionalProperties": true
    },
    "toolRun": {
      "type": "object",
      "required": ["name", "displayName", "description", "action", "kind", "package", "packageFeature", "tool", "toolPath", "toolSource", "driver", "driverPath", "driverSource", "driverProtocol", "capabilities", "state", "diagnostic", "inputContract", "inputScope", "includeGenerated", "configCount", "configNames", "configPaths", "configOptional", "includes", "excludes", "inputFiles", "gate", "failOn", "baseline", "newFindingsOnly", "cache", "jobs", "timeout", "failureStrategy", "weight", "maxParallelism", "exclusiveResource", "reportCount", "reportNames", "reportPaths", "reportFormats", "dependencies"],
      "properties": {
        "name": { "type": "string" },
        "displayName": { "type": "string" },
        "description": { "type": "string" },
        "action": { "type": "string" },
        "kind": { "type": "string", "enum": ["Analyze", "Format", "Scan", "Transform", "Report", "Custom", ""] },
        "package": { "type": "string" },
        "packageFeature": { "type": "string" },
        "tool": { "type": "string" },
        "toolPath": { "type": "string" },
        "toolSource": { "type": "string" },
        "driver": { "type": "string" },
        "driverPath": { "type": "string" },
        "driverSource": { "type": "string" },
        "driverProtocol": { "type": "string" },
        "capabilities": { "type": "array", "items": { "type": "string" } },
        "state": { "type": "string", "enum": ["ready", "disabled", "excluded", "unavailable", "invalid"] },
        "diagnostic": { "type": "string" },
        "inputContract": { "type": "string" },
        "inputScope": { "type": "string", "enum": ["Product", "ProductClosure", "Workspace", "Explicit", "ActiveFile", "ChangedFiles"] },
        "includeGenerated": { "type": "boolean" },
        "configCount": { "type": "integer", "minimum": 0 },
        "configNames": { "type": "array", "items": { "type": "string" } },
        "configPaths": { "type": "array", "items": { "type": "string" } },
        "configOptional": { "type": "array", "items": { "type": "boolean" } },
        "includes": { "type": "array", "items": { "type": "string" } },
        "excludes": { "type": "array", "items": { "type": "string" } },
        "inputFiles": { "type": "array", "items": { "type": "string" } },
        "gate": { "type": "boolean" },
        "failOn": { "type": "string", "enum": ["Info", "Warning", "Error", "Fatal"] },
        "baseline": { "type": "string" },
        "newFindingsOnly": { "type": "boolean" },
        "cache": { "type": "string", "enum": ["Off", "ReadOnly", "WriteOnly", "ReadWrite"] },
        "jobs": { "type": "string" },
        "timeout": { "type": "string" },
        "failureStrategy": { "type": "string", "enum": ["Continue", "FailFast", "DependencyAware"] },
        "weight": { "type": "integer", "minimum": 1 },
        "maxParallelism": { "type": "integer", "minimum": 1 },
        "exclusiveResource": { "type": "string" },
        "reportCount": { "type": "integer", "minimum": 0 },
        "reportNames": { "type": "array", "items": { "type": "string" } },
        "reportPaths": { "type": "array", "items": { "type": "string" } },
        "reportFormats": { "type": "array", "items": { "type": "string" } },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "provenance": { "$ref": "#/$defs/provenance" },
        "originProvenance": { "$ref": "#/$defs/provenance" }
      },
      "additionalProperties": true
    },
    "toolingPlan": {
      "type": "object",
      "required": ["tools", "drivers", "actions", "runs", "inputSets", "dependencies", "policies", "reports", "diagnostics"],
      "properties": {
        "tools": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["identity", "name", "package", "kind", "executable", "resolvedPath", "resolutionSource", "versionRange", "systemExecutable"],
            "properties": {
              "identity": { "type": "string" },
              "name": { "type": "string" },
              "package": { "type": "string" },
              "resolvedPath": { "type": "string" },
              "resolutionSource": { "type": "string" },
              "systemExecutable": { "type": "boolean" },
              "provenance": { "$ref": "#/$defs/provenance" }
            },
            "additionalProperties": true
          }
        },
        "drivers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["identity", "name", "package", "protocol", "version", "executable", "resolvedPath", "resolutionSource", "probe", "capabilities"],
            "properties": {
              "identity": { "type": "string" },
              "protocol": { "type": "string" },
              "probe": { "type": "boolean" },
              "capabilities": { "type": "array", "items": { "type": "string" } },
              "provenance": { "$ref": "#/$defs/provenance" }
            },
            "additionalProperties": true
          }
        },
        "actions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["identity", "name", "package", "kind", "tool", "driver", "inputContracts", "capabilities", "defaultInputScope", "environment"],
            "properties": {
              "identity": { "type": "string" },
              "kind": { "type": "string" },
              "inputContracts": { "type": "array", "items": { "type": "string" } },
              "capabilities": { "type": "array", "items": { "type": "string" } },
              "environment": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name", "required", "secret", "cacheKey", "resolved"],
                  "properties": {
                    "name": { "type": "string" },
                    "required": { "type": "boolean" },
                    "secret": { "type": "boolean" },
                    "cacheKey": { "type": "boolean" },
                    "resolved": { "type": "boolean" }
                  },
                  "additionalProperties": false
                }
              },
              "provenance": { "$ref": "#/$defs/provenance" }
            },
            "additionalProperties": true
          }
        },
        "runs": {
          "type": "array",
          "items": { "$ref": "#/$defs/toolRun" }
        },
        "inputSets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["identity", "run", "contract", "scope", "state", "source", "signature", "includeGenerated", "files", "translationUnits"],
            "properties": {
              "identity": { "type": "string" },
              "contract": { "type": "string" },
              "files": { "type": "array", "items": { "type": "string" } },
              "translationUnits": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["source", "workingDirectory", "compiler", "arguments", "targetPlatform", "language", "owner", "generated", "commandDigest"],
                  "properties": {
                    "source": { "type": "string" },
                    "workingDirectory": { "type": "string" },
                    "compiler": { "type": "string" },
                    "arguments": { "type": "array", "items": { "type": "string" } },
                    "targetPlatform": { "type": "string" },
                    "language": { "type": "string" },
                    "owner": { "type": "string" },
                    "generated": { "type": "boolean" },
                    "commandDigest": { "type": "string" }
                  },
                  "additionalProperties": false
                }
              }
            },
            "additionalProperties": true
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["from", "to", "kind"],
            "properties": {
              "from": { "type": "string" },
              "to": { "type": "string" },
              "kind": { "type": "string", "enum": ["run", "phase"] }
            },
            "additionalProperties": false
          }
        },
        "policies": { "type": "array", "items": { "type": "object" } },
        "reports": { "type": "array", "items": { "type": "object" } },
        "diagnostics": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": true
    },
    "plans": {
      "type": "object",
      "required": [
        "packages",
        "packageFeatures",
        "build",
        "generators",
        "stage",
        "runtime",
        "environment",
        "launch",
        "launches",
        "packageOutputs",
        "publish",
        "tooling",
        "diagnostics"
      ],
      "properties": {
        "packages": {
          "type": "array",
          "items": { "$ref": "#/$defs/package" }
        },
        "packageFeatures": {
          "type": "array",
          "items": { "$ref": "#/$defs/packageFeature" }
        },
        "build": { "$ref": "#/$defs/buildPlan" },
        "generators": {
          "type": "array",
          "items": { "$ref": "#/$defs/generator" }
        },
        "stage": { "$ref": "#/$defs/stagePlan" },
        "runtime": { "$ref": "#/$defs/runtimePlan" },
        "environment": { "$ref": "#/$defs/environmentPlan" },
        "launch": { "$ref": "#/$defs/launch" },
        "launches": {
          "type": "array",
          "items": { "$ref": "#/$defs/launch" }
        },
        "packageOutputs": {
          "type": "array",
          "items": { "$ref": "#/$defs/packageOutput" }
        },
        "publish": {
          "type": "array",
          "items": { "$ref": "#/$defs/publish" }
        },
        "tooling": { "$ref": "#/$defs/toolingPlan" },
        "diagnostics": {
          "type": "array",
          "items": { "$ref": "#/$defs/diagnostic" }
        }
      },
      "additionalProperties": true
    },
    "compositionGraph": {
      "type": "object",
      "required": [
        "schemaVersion",
        "kind",
        "state",
        "facets",
        "identity",
        "conventions",
        "properties",
        "product",
        "selection",
        "facetsSummary",
        "plans"
      ],
      "properties": {
        "schemaVersion": { "const": "4.0" },
        "kind": { "const": "NGIN.CompositionGraph" },
        "state": { "type": "string", "enum": ["resolved", "diagnostic"] },
        "facets": { "$ref": "#/$defs/stringArray" },
        "identity": { "$ref": "#/$defs/identity" },
        "conventions": {
          "type": "array",
          "items": { "$ref": "#/$defs/convention" }
        },
        "properties": {
          "type": "array",
          "items": { "$ref": "#/$defs/property" }
        },
        "product": { "$ref": "#/$defs/product" },
        "selection": { "$ref": "#/$defs/selection" },
        "facetsSummary": { "$ref": "#/$defs/facetsSummary" },
        "plans": { "$ref": "#/$defs/plans" }
      },
      "additionalProperties": true
    },
    "compositionGraphPlan": {
      "type": "object",
      "required": [
        "schemaVersion",
        "kind",
        "plan",
        "state",
        "identity",
        "data",
        "diagnostics"
      ],
      "properties": {
        "schemaVersion": { "const": "4.0" },
        "kind": { "const": "NGIN.CompositionGraphPlan" },
        "plan": {
          "type": "string",
          "enum": [
            "build",
            "stage",
            "package",
            "package-output",
            "launch",
            "runtime",
            "environment",
            "publish",
            "tooling"
          ]
        },
        "state": { "type": "string", "enum": ["resolved", "diagnostic"] },
        "identity": { "$ref": "#/$defs/planIdentity" },
        "data": {
          "anyOf": [
            { "type": "null" },
            { "$ref": "#/$defs/buildPlan" },
            { "$ref": "#/$defs/stagePlan" },
            { "$ref": "#/$defs/runtimePlan" },
            { "$ref": "#/$defs/environmentPlan" },
            { "$ref": "#/$defs/launch" },
            { "$ref": "#/$defs/toolingPlan" },
            {
              "type": "object",
              "additionalProperties": true
            }
          ]
        },
        "diagnostics": {
          "type": "array",
          "items": { "$ref": "#/$defs/diagnostic" }
        }
      },
      "additionalProperties": true
    }
  }
}
