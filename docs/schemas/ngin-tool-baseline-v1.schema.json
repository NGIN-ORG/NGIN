{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ngin.dev/schemas/ngin-tool-baseline-v1.schema.json",
  "title": "NGIN Tool Baseline 1",
  "type": "object",
  "required": ["schemaVersion", "kind", "run", "findings"],
  "properties": {
    "schemaVersion": { "const": "1.0" },
    "kind": { "const": "NGIN.ToolBaseline" },
    "run": { "type": "string", "minLength": 1 },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["fingerprint", "code", "message", "reason"],
        "properties": {
          "fingerprint": { "type": "string", "minLength": 1 },
          "code": { "type": "string" },
          "message": { "type": "string" },
          "reason": { "type": "string", "minLength": 1 },
          "expires": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
