{
  "schemaVersion": 1,
  "name": "NGIN.Samples.ApplicationModel",
  "defaultTarget": "Sandbox.Game",
  "targets": [
    {
      "name": "Tools.Cli",
      "type": "Program",
      "profile": "ConsoleApp",
      "platform": "linux-x64",
      "enableReflection": false,
      "packages": [
        {
          "name": "NGIN.ECS",
          "versionRange": ">=0.1.0 <1.0.0"
        }
      ],
      "modules": {
        "enable": [
          "Core.Hosting"
        ],
        "disable": []
      },
      "plugins": {
        "enable": [],
        "disable": []
      },
      "environmentName": "Dev",
      "configSources": [
        "config/cli.json"
      ],
      "workingDirectory": "."
    },
    {
      "name": "Tools.Editor",
      "type": "Editor",
      "profile": "Editor",
      "platform": "linux-x64",
      "enableReflection": true,
      "packages": [
        {
          "name": "NGIN.ECS",
          "versionRange": ">=0.1.0 <1.0.0"
        },
        {
          "name": "NGIN.Editor",
          "versionRange": ">=0.1.0 <1.0.0"
        }
      ],
      "modules": {
        "enable": [
          "Core.Hosting",
          "Domain.ECS",
          "Editor.Workspace"
        ],
        "disable": []
      },
      "plugins": {
        "enable": [
          "NGIN.Diagnostics"
        ],
        "disable": []
      },
      "environmentName": "Dev",
      "configSources": [
        "config/editor.json"
      ],
      "workingDirectory": "."
    },
    {
      "name": "Sandbox.Game",
      "type": "Runtime",
      "profile": "Game",
      "platform": "linux-x64",
      "enableReflection": false,
      "packages": [
        {
          "name": "NGIN.ECS",
          "versionRange": ">=0.1.0 <1.0.0"
        }
      ],
      "modules": {
        "enable": [
          "Core.Hosting",
          "Domain.ECS"
        ],
        "disable": []
      },
      "plugins": {
        "enable": [],
        "disable": []
      },
      "environmentName": "Dev",
      "configSources": [
        "config/game.json"
      ],
      "workingDirectory": "."
    }
  ]
}
