{
  "schemaVersion": 1,
  "name": "NGIN.Core.BasicHost",
  "defaultTarget": "Samples.BasicHost",
  "targets": [
    {
      "name": "Samples.BasicHost",
      "type": "Program",
      "profile": "ConsoleApp",
      "platform": "linux-x64",
      "enableReflection": false,
      "packages": [
        {
          "name": "Samples.DemoPackage",
          "versionRange": ">=0.1.0 <1.0.0",
          "optional": false
        }
      ],
      "modules": {
        "enable": [
          "App.BasicHost"
        ],
        "disable": []
      },
      "plugins": {
        "enable": [],
        "disable": []
      },
      "environmentName": "Dev",
      "configSources": [
        "app.cfg"
      ],
      "workingDirectory": "."
    }
  ]
}
