{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ngin.dev/schemas/package-lock.schema.json",
  "title": "NGIN Package Lockfile",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "project",
    "defaultTarget",
    "targets"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "projectPath",
        "manifestHash"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "projectPath": {
          "type": "string",
          "minLength": 1
        },
        "manifestHash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "defaultTarget": {
      "type": "string",
      "minLength": 1
    },
    "targets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/targetLock"
      }
    }
  },
  "$defs": {
    "packageDependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "versionRange",
        "optional"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "versionRange": {
          "type": "string"
        },
        "optional": {
          "type": "boolean"
        }
      }
    },
    "providedContent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "modules",
        "plugins"
      ],
      "properties": {
        "modules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "plugins": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "materializedContent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "kind",
        "cachePath",
        "hash"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "minLength": 1
        },
        "targetPath": {
          "type": "string",
          "minLength": 1
        },
        "cachePath": {
          "type": "string",
          "minLength": 1
        },
        "hash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "stringArrayMap": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "stagePlan": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "requiredModules",
          "optionalModules"
        ],
        "properties": {
          "requiredModules": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "optionalModules": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "lockedPackage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "version",
        "source",
        "manifestPath",
        "manifestHash",
        "cacheEntryPath",
        "cacheManifestPath",
        "dependencies",
        "provides"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "source": {
          "type": "string"
        },
        "manifestPath": {
          "type": "string"
        },
        "manifestHash": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "cacheEntryPath": {
          "type": "string",
          "minLength": 1
        },
        "cacheManifestPath": {
          "type": "string",
          "minLength": 1
        },
        "dependencies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/packageDependency"
          }
        },
        "provides": {
          "$ref": "#/$defs/providedContent"
        },
        "contents": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/materializedContent"
          }
        }
      }
    },
    "targetLock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "source",
        "type",
        "profile",
        "platform",
        "enableReflection",
        "configSources",
        "packages",
        "providedByModule",
        "providedByPlugin",
        "requiredModules",
        "optionalModules",
        "enabledPlugins",
        "stages",
        "dependencyEdges",
        "packageEdges"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "minLength": 1
        },
        "profile": {
          "type": "string",
          "minLength": 1
        },
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "enableReflection": {
          "type": "boolean"
        },
        "environmentName": {
          "type": "string"
        },
        "configSources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "workingDirectory": {
          "type": "string"
        },
        "packages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/lockedPackage"
          }
        },
        "providedByModule": {
          "$ref": "#/$defs/stringArrayMap"
        },
        "providedByPlugin": {
          "$ref": "#/$defs/stringArrayMap"
        },
        "requiredModules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "optionalModules": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "enabledPlugins": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stages": {
          "$ref": "#/$defs/stagePlan"
        },
        "dependencyEdges": {
          "$ref": "#/$defs/stringArrayMap"
        },
        "packageEdges": {
          "$ref": "#/$defs/stringArrayMap"
        }
      }
    }
  }
}
