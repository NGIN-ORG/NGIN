{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ngin.dev/schemas/module-graph.schema.json",
  "title": "NGIN Module Graph Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "modules",
    "plugins",
    "targets"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "modules": {
      "type": "array",
      "items": {
        "$ref": "./module.schema.json"
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "$ref": "./plugin-bundle.schema.json"
      }
    },
    "targets": {
      "type": "array",
      "items": {
        "$ref": "./target.schema.json"
      }
    }
  }
}
