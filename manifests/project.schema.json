{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ngin.dev/schemas/project.schema.json",
  "title": "NGIN Project Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "name",
    "defaultTarget",
    "targets"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "defaultTarget": {
      "type": "string",
      "minLength": 1
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/targetDefinition"
      }
    }
  },
  "$defs": {
    "packageReference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_-]*\\.[A-Za-z0-9_.-]+$"
        },
        "versionRange": {
          "type": "string"
        },
        "optional": {
          "type": "boolean"
        }
      }
    },
    "moduleSelection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enable",
        "disable"
      ],
      "properties": {
        "enable": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9]*\\.[A-Za-z0-9_.-]+$"
          },
          "uniqueItems": true
        },
        "disable": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9]*\\.[A-Za-z0-9_.-]+$"
          },
          "uniqueItems": true
        }
      }
    },
    "pluginSelection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enable",
        "disable"
      ],
      "properties": {
        "enable": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_-]*\\.[A-Za-z0-9_.-]+$"
          },
          "uniqueItems": true
        },
        "disable": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_-]*\\.[A-Za-z0-9_.-]+$"
          },
          "uniqueItems": true
        }
      }
    },
    "targetDefinition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "type",
        "profile",
        "platform",
        "enableReflection",
        "packages",
        "modules",
        "plugins"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "type": {
          "type": "string",
          "enum": [
            "Runtime",
            "Editor",
            "Program",
            "Developer"
          ]
        },
        "profile": {
          "type": "string",
          "enum": [
            "ConsoleApp",
            "GuiApp",
            "Game",
            "Editor",
            "Service",
            "TestHost"
          ]
        },
        "platform": {
          "type": "string",
          "minLength": 1
        },
        "enableReflection": {
          "type": "boolean"
        },
        "packages": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/packageReference"
          }
        },
        "modules": {
          "$ref": "#/$defs/moduleSelection"
        },
        "plugins": {
          "$ref": "#/$defs/pluginSelection"
        },
        "environmentName": {
          "type": "string"
        },
        "configSources": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        },
        "workingDirectory": {
          "type": "string"
        }
      }
    }
  }
}
