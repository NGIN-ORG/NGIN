{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ngin.dev/schemas/package.schema.json",
  "title": "NGIN Package Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "name",
    "version",
    "compatiblePlatformRange",
    "platforms",
    "dependencies",
    "provides"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "name": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_-]*\\.[A-Za-z0-9_.-]+$"
    },
    "version": {
      "type": "string",
      "pattern": "^(0|[1-9]\\d*)\\.(0|[1-9]\\d*)\\.(0|[1-9]\\d*)(?:-[0-9A-Za-z.-]+)?$"
    },
    "compatiblePlatformRange": {
      "type": "string"
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "dependencies": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/packageDependency"
      }
    },
    "bootstrap": {
      "$ref": "#/$defs/packageBootstrap"
    },
    "contents": {
      "$ref": "#/$defs/packageContents"
    },
    "provides": {
      "$ref": "#/$defs/providedContent"
    }
  },
  "$defs": {
    "packageDependency": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "versionRange",
        "optional"
      ],
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[A-Za-z][A-Za-z0-9_-]*\\.[A-Za-z0-9_.-]+$"
        },
        "versionRange": {
          "type": "string"
        },
        "optional": {
          "type": "boolean"
        }
      }
    },
    "packageBootstrap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mode",
        "entryPoint",
        "autoApply"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "BuilderHookV1"
          ]
        },
        "entryPoint": {
          "type": "string",
          "pattern": "^[A-Za-z_][A-Za-z0-9_]*$"
        },
        "autoApply": {
          "type": "boolean"
        }
      }
    },
    "packageContentFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "kind"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "asset",
            "config",
            "binary",
            "plugin",
            "tool",
            "other"
          ]
        },
        "targetPath": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "packageContents": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "files"
      ],
      "properties": {
        "files": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/packageContentFile"
          }
        }
      }
    },
    "providedContent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "modules",
        "plugins"
      ],
      "properties": {
        "modules": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9]*\\.[A-Za-z0-9_.-]+$"
          },
          "uniqueItems": true
        },
        "plugins": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9_-]*\\.[A-Za-z0-9_.-]+$"
          },
          "uniqueItems": true
        }
      }
    }
  }
}
