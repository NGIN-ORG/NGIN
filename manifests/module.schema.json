{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ngin.dev/schemas/module.schema.json",
  "title": "NGIN Runtime Module Descriptor",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "name",
    "family",
    "type",
    "component",
    "version",
    "compatiblePlatformRange",
    "platforms",
    "loadPhase",
    "dependencies",
    "flags"
  ],
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9]*\\.[A-Za-z0-9_.-]+$"
    },
    "family": {
      "type": "string",
      "enum": [
        "Base",
        "Reflection",
        "RuntimeSvc",
        "Platform",
        "Editor",
        "Domain",
        "App"
      ]
    },
    "type": {
      "type": "string",
      "enum": [
        "Runtime",
        "Editor",
        "Program",
        "Developer",
        "ThirdParty"
      ]
    },
    "component": {
      "type": "string",
      "pattern": "^NGIN\\.[A-Za-z0-9_.-]+$"
    },
    "version": {
      "type": "string"
    },
    "compatiblePlatformRange": {
      "type": "string"
    },
    "platforms": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      },
      "uniqueItems": true
    },
    "loadPhase": {
      "type": "string"
    },
    "dependencies": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "optional"
      ],
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9]*\\.[A-Za-z0-9_.-]+$"
          },
          "uniqueItems": true
        },
        "optional": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^[A-Za-z][A-Za-z0-9]*\\.[A-Za-z0-9_.-]+$"
          },
          "uniqueItems": true
        }
      }
    },
    "flags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "editorOnly",
        "requiresReflection"
      ],
      "properties": {
        "editorOnly": {
          "type": "boolean"
        },
        "requiresReflection": {
          "type": "boolean"
        }
      }
    }
  }
}
