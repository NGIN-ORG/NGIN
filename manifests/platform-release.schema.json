{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ngin.dev/schemas/platform-release.schema.json",
  "title": "NGIN Platform Release Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "platformVersion",
    "releaseDate",
    "components"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "platformVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(-[A-Za-z0-9.-]+)?$"
    },
    "releaseDate": {
      "type": "string",
      "format": "date"
    },
    "channel": {
      "type": "string",
      "enum": [
        "dev",
        "alpha",
        "beta",
        "stable"
      ]
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "./components.schema.json"
      }
    },
    "compatibility": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "moduleGraphSpec": { "type": "string" },
        "pluginAbiVersion": {
          "type": [
            "integer",
            "null"
          ]
        }
      }
    },
    "releaseNotes": {
      "type": "string"
    }
  }
}

