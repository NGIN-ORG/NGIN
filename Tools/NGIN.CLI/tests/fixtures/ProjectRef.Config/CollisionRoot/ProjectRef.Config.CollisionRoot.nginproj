<?xml version="1.0" encoding="utf-8"?>
<Project SchemaVersion="4"
         Name="ProjectRef.Config.CollisionRoot"
         DefaultProfile="Runtime">
  <Application>
    <Uses>
      <Project Name="ProjectRef.Config.CollisionLibA"
               Path="../CollisionLibA/ProjectRef.Config.CollisionLibA.nginproj" />
      <Project Name="ProjectRef.Config.CollisionLibB"
               Path="../CollisionLibB/ProjectRef.Config.CollisionLibB.nginproj" />
    </Uses>
    <Build>
      <Sources Path="src/**.cpp" />
    </Build>
    <Launch Executable="$(OutputName)" WorkingDirectory="." />
  </Application>
  <Profile Name="Runtime">
    <Defaults>
      <Optimization Mode="Off" />
      <DebugSymbols Enabled="true" />
      <LinkTimeOptimization Enabled="false" />
      <TargetPlatform Name="linux-x64" />
      <Environment Name="development" />
    </Defaults>
  </Profile>
</Project>
