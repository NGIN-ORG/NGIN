{
  "name": "ngin-tools",
  "displayName": "NGIN Tools",
  "description": "CLI-first build, run, and debug workflows for NGIN projects in VS Code.",
  "version": "0.1.0",
  "publisher": "ngin",
  "license": "Apache-2.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/NGIN-ORG/NGIN.git",
    "directory": "Tools/NGIN.VSCode"
  },
  "engines": {
    "vscode": "^1.86.0"
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "Inspection remains available, but NGIN build and tooling processes require workspace trust."
    }
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Debuggers"
  ],
  "activationEvents": [
    "onDebugResolve:ngin",
    "workspaceContains:**/*.nginproj",
    "workspaceContains:**/*.nginsettings"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "watch": "node ./scripts/build.mjs --watch",
    "typecheck": "tsc -p ./tsconfig.json --noEmit && tsc -p ./tsconfig.tests.json --noEmit",
    "test:unit": "tsc -p ./tsconfig.tests.json && node --test ./dist-test/test/unit/*.test.js",
    "test:integration": "tsc -p ./tsconfig.tests.json && node ./dist-test/test/integration/runTest.js",
    "test": "npm run test:unit && npm run test:integration"
  },
  "dependencies": {
    "fast-xml-parser": "^5.8.0",
    "vscode-cpptools": "^7.1.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.2",
    "@types/vscode": "^1.86.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "mocha": "^11.1.0",
    "ovsx": "^0.10.12",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "encoding-sniffer": "^1.0.2",
    "glob": "^13.0.6",
    "mocha": {
      "diff": "^8.0.3",
      "serialize-javascript": "^7.0.5"
    }
  },
  "contributes": {
    "languages": [
      {
        "id": "ngin",
        "aliases": [
          "NGIN"
        ],
        "extensions": [
          ".ngin",
          ".nginproj",
          ".nginpkg",
          ".nginlaunch",
          ".nginsettings"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ngin",
        "scopeName": "source.ngin",
        "path": "./syntaxes/ngin.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "ngin",
        "path": "./snippets/ngin.code-snippets"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ngin",
          "title": "NGIN",
          "icon": "./media/ngin-activity.svg"
        }
      ]
    },
    "views": {
      "ngin": [
        {
          "id": "nginWorkspace",
          "name": "Workspace",
          "icon": "./media/ngin-activity.svg"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "ngin.projectEditor",
        "displayName": "NGIN Project Editor",
        "selector": [
          {
            "filenamePattern": "*.nginproj"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "ngin.selectProject",
        "title": "Select Project",
        "category": "NGIN"
      },
      {
        "command": "ngin.selectProfile",
        "title": "Select Profile",
        "category": "NGIN",
        "icon": "$(settings-gear)"
      },
      {
        "command": "ngin.build",
        "title": "Build",
        "category": "NGIN",
        "icon": "$(tools)"
      },
      {
        "command": "ngin.publish",
        "title": "Publish…",
        "category": "NGIN",
        "icon": "$(cloud-upload)"
      },
      {
        "command": "ngin.configure",
        "title": "Configure",
        "category": "NGIN"
      },
      {
        "command": "ngin.clean",
        "title": "Clean",
        "category": "NGIN"
      },
      {
        "command": "ngin.rebuild",
        "title": "Rebuild",
        "category": "NGIN"
      },
      {
        "command": "ngin.run",
        "title": "Run",
        "category": "NGIN",
        "icon": "$(play)"
      },
      {
        "command": "ngin.debug",
        "title": "Debug",
        "category": "NGIN"
      },
      {
        "command": "ngin.validate",
        "title": "Validate",
        "category": "NGIN"
      },
      {
        "command": "ngin.analyze",
        "title": "Analyze",
        "category": "NGIN"
      },
      {
        "command": "ngin.analyzeActiveFile",
        "title": "Analyze Active File",
        "category": "NGIN"
      },
      {
        "command": "ngin.analyzeChangedFiles",
        "title": "Analyze Changed Files…",
        "category": "NGIN"
      },
      {
        "command": "ngin.applyToolEdits",
        "title": "Apply Tool Edits",
        "category": "NGIN"
      },
      {
        "command": "ngin.runToolRun",
        "title": "Run Tool",
        "category": "NGIN",
        "icon": "$(play)"
      },
      {
        "command": "ngin.runToolActiveFile",
        "title": "Run on Active File",
        "category": "NGIN"
      },
      {
        "command": "ngin.runToolChangedFiles",
        "title": "Run on Changed Files…",
        "category": "NGIN"
      },
      {
        "command": "ngin.previewToolChanges",
        "title": "Preview Changes",
        "category": "NGIN",
        "icon": "$(preview)"
      },
      {
        "command": "ngin.configureToolRun",
        "title": "Configure Tool…",
        "category": "NGIN",
        "icon": "$(settings-gear)"
      },
      {
        "command": "ngin.configureToolRunOnSave",
        "title": "Configure Run on Save…",
        "category": "NGIN"
      },
      {
        "command": "ngin.diagnoseToolRun",
        "title": "Diagnose Tool",
        "category": "NGIN",
        "icon": "$(wrench)"
      },
      {
        "command": "ngin.clearToolDiagnostics",
        "title": "Clear Tool Diagnostics",
        "category": "NGIN"
      },
      {
        "command": "ngin.copyToolInvocation",
        "title": "Copy Tool Invocation",
        "category": "NGIN"
      },
      {
        "command": "ngin.applyToolRunEdits",
        "title": "Apply Changes",
        "category": "NGIN"
      },
      {
        "command": "ngin.addToolAction",
        "title": "Add Tool Action",
        "category": "NGIN"
      },
      {
        "command": "ngin.toolingPlan",
        "title": "Show Tooling Plan",
        "category": "NGIN"
      },
      {
        "command": "ngin.graph",
        "title": "Graph",
        "category": "NGIN"
      },
      {
        "command": "ngin.variablesExplain",
        "title": "Explain Variables",
        "category": "NGIN"
      },
      {
        "command": "ngin.settingsInit",
        "title": "Initialize Local Settings",
        "category": "NGIN"
      },
      {
        "command": "ngin.workspaceStatus",
        "title": "Workspace Status",
        "category": "NGIN"
      },
      {
        "command": "ngin.workspaceDoctor",
        "title": "Workspace Doctor",
        "category": "NGIN"
      },
      {
        "command": "ngin.openLastLaunchManifest",
        "title": "Open Last Build Manifest",
        "category": "NGIN"
      },
      {
        "command": "ngin.openProjectManifest",
        "title": "Open Project Manifest",
        "category": "NGIN"
      },
      {
        "command": "ngin.openProjectXmlSource",
        "title": "Open Project XML Source",
        "category": "NGIN"
      },
      {
        "command": "ngin.openPath",
        "title": "Open",
        "category": "NGIN"
      },
      {
        "command": "ngin.revealPath",
        "title": "Reveal in File Explorer",
        "category": "NGIN"
      },
      {
        "command": "ngin.copyPath",
        "title": "Copy Path",
        "category": "NGIN"
      },
      {
        "command": "ngin.explainSelection",
        "title": "Explain Selection",
        "category": "NGIN"
      },
      {
        "command": "ngin.showResolvedInputs",
        "title": "Show Resolved Inputs",
        "category": "NGIN"
      },
      {
        "command": "ngin.showInactiveTooling",
        "title": "Show Inactive Tooling",
        "category": "NGIN"
      },
      {
        "command": "ngin.setActiveProject",
        "title": "Set Active Project",
        "category": "NGIN"
      },
      {
        "command": "ngin.projectNewSourceFile",
        "title": "New Source File",
        "category": "NGIN"
      },
      {
        "command": "ngin.projectNewConfigFile",
        "title": "New Config File",
        "category": "NGIN"
      },
      {
        "command": "ngin.projectNewFolder",
        "title": "New Folder",
        "category": "NGIN"
      },
      {
        "command": "ngin.projectCopy",
        "title": "Copy",
        "category": "NGIN"
      },
      {
        "command": "ngin.projectDuplicate",
        "title": "Duplicate",
        "category": "NGIN"
      },
      {
        "command": "ngin.projectRename",
        "title": "Rename",
        "category": "NGIN"
      },
      {
        "command": "ngin.projectDelete",
        "title": "Delete",
        "category": "NGIN"
      },
      {
        "command": "ngin.refresh",
        "title": "Refresh",
        "category": "NGIN",
        "icon": {
          "light": "./media/refresh-light.svg",
          "dark": "./media/refresh-dark.svg"
        }
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "ngin.openPath",
          "when": "false"
        },
        {
          "command": "ngin.openProjectXmlSource",
          "when": "resourceExtname == .nginproj"
        },
        {
          "command": "ngin.revealPath",
          "when": "false"
        },
        {
          "command": "ngin.copyPath",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "ngin.build",
          "when": "view == nginWorkspace",
          "group": "navigation@1"
        },
        {
          "command": "ngin.run",
          "when": "view == nginWorkspace",
          "group": "navigation@2"
        },
        {
          "command": "ngin.publish",
          "when": "view == nginWorkspace",
          "group": "navigation@3"
        },
        {
          "command": "ngin.selectProfile",
          "when": "view == nginWorkspace",
          "group": "navigation@4"
        },
        {
          "command": "ngin.refresh",
          "when": "view == nginWorkspace",
          "group": "navigation@5"
        },
        {
          "command": "ngin.validate",
          "when": "view == nginWorkspace"
        },
        {
          "command": "ngin.configure",
          "when": "view == nginWorkspace"
        },
        {
          "command": "ngin.rebuild",
          "when": "view == nginWorkspace"
        },
        {
          "command": "ngin.clean",
          "when": "view == nginWorkspace"
        },
        {
          "command": "ngin.debug",
          "when": "view == nginWorkspace"
        },
        {
          "command": "ngin.graph",
          "when": "view == nginWorkspace"
        },
        {
          "command": "ngin.showResolvedInputs",
          "when": "view == nginWorkspace"
        },
        {
          "command": "ngin.showInactiveTooling",
          "when": "view == nginWorkspace"
        }
      ],
      "view/item/context": [
        {
          "command": "ngin.workspaceStatus",
          "when": "view == nginWorkspace && viewItem == nginWorkspace",
          "group": "navigation@1"
        },
        {
          "command": "ngin.workspaceDoctor",
          "when": "view == nginWorkspace && viewItem == nginWorkspace",
          "group": "navigation@2"
        },
        {
          "command": "ngin.openProjectManifest",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProjectManifest)$/",
          "group": "navigation@1"
        },
        {
          "command": "ngin.openPath",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProjectGeneratedFile|nginProjectDependency|nginProjectReference|nginProjectInspectEntry.*openable)$/",
          "group": "navigation@2"
        },
        {
          "command": "ngin.revealPath",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProjectManifest|nginProjectGeneratedFile|nginProjectGeneratedFolder|nginProjectDependency|nginProjectReference|nginProjectInspectEntry.*openable)$/",
          "group": "navigation@3"
        },
        {
          "command": "ngin.copyPath",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProjectManifest|nginProjectGeneratedFile|nginProjectGeneratedFolder|nginProjectDependency|nginProjectReference|nginProjectInspectEntry.*openable)$/",
          "group": "navigation@4"
        },
        {
          "command": "ngin.setActiveProject",
          "when": "view == nginWorkspace && viewItem == nginProject",
          "group": "navigation@5"
        },
        {
          "command": "ngin.runToolRun",
          "when": "view == nginWorkspace && viewItem =~ /^nginProjectInspectEntry\\.toolRun\\.ready/ && !(viewItem =~ /\\.edits/)",
          "group": "inline@1"
        },
        {
          "command": "ngin.previewToolChanges",
          "when": "view == nginWorkspace && viewItem =~ /^nginProjectInspectEntry\\.toolRun\\.ready.*\\.edits/",
          "group": "inline@1"
        },
        {
          "command": "ngin.diagnoseToolRun",
          "when": "view == nginWorkspace && viewItem =~ /^nginProjectInspectEntry\\.toolRun\\.(unavailable|invalid)/",
          "group": "inline@1"
        },
        {
          "command": "ngin.runToolRun",
          "when": "view == nginWorkspace && viewItem =~ /^nginProjectInspectEntry\\.toolRun\\.ready/",
          "group": "ngin.tool@1"
        },
        {
          "command": "ngin.runToolActiveFile",
          "when": "view == nginWorkspace && viewItem =~ /^nginProjectInspectEntry\\.toolRun\\.ready.*\\.activeFile/",
          "group": "ngin.tool@2"
        },
        {
          "command": "ngin.runToolChangedFiles",
          "when": "view == nginWorkspace && viewItem =~ /^nginProjectInspectEntry\\.toolRun\\.ready.*\\.changedFiles/",
          "group": "ngin.tool@3"
        },
        {
          "command": "ngin.configureToolRun",
          "when": "view == nginWorkspace && viewItem =~ /^nginProjectInspectEntry\\.toolRun/",
          "group": "ngin.tool@4"
        },
        {
          "command": "ngin.configureToolRunOnSave",
          "when": "view == nginWorkspace && viewItem =~ /^nginProjectInspectEntry\\.toolRun/",
          "group": "ngin.tool@5"
        },
        {
          "command": "ngin.applyToolRunEdits",
          "when": "view == nginWorkspace && viewItem =~ /^nginProjectInspectEntry\\.toolRun.*\\.edits/",
          "group": "ngin.tool@6"
        },
        {
          "command": "ngin.clearToolDiagnostics",
          "when": "view == nginWorkspace && viewItem =~ /^nginProjectInspectEntry\\.toolRun/",
          "group": "ngin.inspect@3"
        },
        {
          "command": "ngin.copyToolInvocation",
          "when": "view == nginWorkspace && viewItem =~ /^nginProjectInspectEntry\\.toolRun/",
          "group": "ngin.inspect@4"
        },
        {
          "command": "ngin.explainSelection",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProjectDependency|nginProjectInspectEntry\\.(tooling|toolRun|launch|detail))/",
          "group": "ngin.inspect@1"
        },
        {
          "command": "ngin.build",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.actions@1"
        },
        {
          "command": "ngin.configure",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.actions@2"
        },
        {
          "command": "ngin.rebuild",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.actions@3"
        },
        {
          "command": "ngin.run",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile|nginProjectGeneratedFolder)$/",
          "group": "ngin.actions@4"
        },
        {
          "command": "ngin.publish",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.actions@5"
        },
        {
          "command": "ngin.debug",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.actions@6"
        },
        {
          "command": "ngin.publish",
          "when": "view == nginWorkspace && viewItem == nginProjectGroup.publish",
          "group": "inline@1"
        },
        {
          "command": "ngin.publish",
          "when": "view == nginWorkspace && viewItem == nginProjectInspectEntry.publish",
          "group": "inline@1"
        },
        {
          "command": "ngin.validate",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@1"
        },
        {
          "command": "ngin.analyze",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@2"
        },
        {
          "command": "ngin.addToolAction",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@2.1"
        },
        {
          "command": "ngin.toolingPlan",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@2.2"
        },
        {
          "command": "ngin.graph",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@3"
        },
        {
          "command": "ngin.variablesExplain",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@4"
        },
        {
          "command": "ngin.settingsInit",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@4"
        },
        {
          "command": "ngin.clean",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@6"
        },
        {
          "command": "ngin.projectNewSourceFile",
          "when": "view == nginWorkspace && viewItem == nginProject",
          "group": "ngin.new@1"
        },
        {
          "command": "ngin.projectNewConfigFile",
          "when": "view == nginWorkspace && viewItem == nginProject",
          "group": "ngin.new@2"
        }
      ]
    },
    "configuration": {
      "title": "NGIN Tools",
      "properties": {
        "ngin.cli.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional explicit path to the `ngin` executable. Relative paths are resolved from the active workspace root."
        },
        "ngin.build.outputRoot": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional staged output root. When set, build output is written to `<outputRoot>/<project>/<profile>`."
        },
        "ngin.tooling.validateManifestOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Validate the current NGIN project after saving an NGIN manifest."
        },
        "ngin.tooling.runOnSave": {
          "type": "object",
          "default": {},
          "additionalProperties": {
            "type": "string",
            "enum": ["activeFile", "all"]
          },
          "markdownDescription": "Per-run save behavior keyed by stable tool run identity. Use `activeFile` for source saves or `all` for manifest saves. Configure this from a Tooling tree item."
        },
        "ngin.tooling.activeFileDebounceMs": {
          "type": "number",
          "default": 350,
          "minimum": 0,
          "description": "Debounce delay for active-file tool runs after saving a source file."
        },
        "ngin.tooling.defaultFormatRun": {
          "type": "string",
          "default": "",
          "markdownDescription": "Stable NGIN tool run identity used for VS Code document formatting when more than one ready Format run accepts a document. Leave empty when the project has one matching formatter."
        },
        "ngin.cli.warnIfStale": {
          "type": "boolean",
          "default": true,
          "description": "Warn once per session if the in-repo development CLI looks older than key CLI source files."
        },
        "ngin.output.verbosity": {
          "type": "string",
          "enum": [
            "compact",
            "normal",
            "verbose"
          ],
          "default": "normal",
          "description": "Controls Output panel detail: compact shows NGIN lifecycle events, normal also streams backend build progress, and verbose requests full CLI and backend detail."
        },
        "ngin.output.color": {
          "type": "string",
          "enum": [
            "never",
            "auto",
            "always"
          ],
          "default": "never",
          "description": "Controls ANSI color requested from the NGIN CLI in the Output panel. Use 'always' only if your VS Code build renders ANSI output correctly."
        },
        "ngin.debug.miDebuggerPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional path to the MI debugger used by `cppdbg` on Linux and macOS."
        },
        "ngin.run.terminalName": {
          "type": "string",
          "default": "NGIN",
          "description": "Integrated terminal name used for `NGIN: Run`."
        },
        "ngin.cpp.configurationProvider.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Register NGIN as a C/C++ custom configuration provider for the current workspace when compile commands are available."
        },
        "ngin.ui.statusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the NGIN workspace, project, profile, build, run, and debug items in the bottom status bar."
        }
      }
    },
    "taskDefinitions": [
      {
        "type": "ngin",
        "required": [
          "command"
        ],
        "properties": {
          "command": {
            "type": "string",
            "enum": [
              "configure",
              "build",
              "clean",
              "rebuild",
              "validate",
              "analyze",
              "graph",
              "workspaceStatus",
              "workspaceDoctor"
            ]
          },
          "project": {
            "type": "string"
          },
          "profile": {
            "type": "string"
          },
          "output": {
            "type": "string"
          }
        }
      }
    ],
    "problemMatchers": [
      {
        "name": "ngin-file",
        "label": "NGIN File Errors",
        "owner": "ngin",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^(?:\\s*-\\s+)?((?:[A-Za-z]:)?[^:]+\\.(?:ngin|nginproj|nginpkg|nginlaunch|nginsettings|xml|cfg)):\\s+(.+)$",
          "file": 1,
          "message": 2
        }
      }
    ],
    "debuggers": [
      {
        "type": "ngin",
        "label": "NGIN",
        "configurationAttributes": {
          "launch": {
            "required": [
              "project",
              "profile"
            ],
            "properties": {
              "project": {
                "type": "string",
                "description": "Path to the .nginproj file."
