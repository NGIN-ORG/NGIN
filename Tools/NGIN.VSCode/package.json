{
  "name": "ngin-tools",
  "displayName": "NGIN Tools",
  "description": "CLI-first build, run, and debug workflows for NGIN projects in VS Code.",
  "version": "0.1.0",
  "publisher": "ngin",
  "license": "UNLICENSED",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/NGIN-ORG/NGIN.git",
    "directory": "Tools/NGIN.VSCode"
  },
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Debuggers"
  ],
  "activationEvents": [
    "onDebugResolve:ngin",
    "workspaceContains:**/*.nginproj",
    "workspaceContains:**/*.nginsettings"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "watch": "node ./scripts/build.mjs --watch",
    "typecheck": "tsc -p ./tsconfig.json --noEmit && tsc -p ./tsconfig.tests.json --noEmit",
    "test:unit": "tsc -p ./tsconfig.tests.json && node --test ./dist-test/test/unit/*.test.js",
    "test:integration": "tsc -p ./tsconfig.tests.json && node ./dist-test/test/integration/runTest.js",
    "test": "npm run test:unit && npm run test:integration"
  },
  "dependencies": {
    "fast-xml-parser": "^5.7.3",
    "vscode-cpptools": "^7.1.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.2",
    "@types/vscode": "^1.86.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.28.0",
    "mocha": "^11.1.0",
    "ovsx": "^0.10.12",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "encoding-sniffer": "^1.0.2",
    "glob": "^13.0.6",
    "mocha": {
      "diff": "^8.0.3",
      "serialize-javascript": "^7.0.5"
    }
  },
  "contributes": {
    "languages": [
      {
        "id": "ngin",
        "aliases": [
          "NGIN"
        ],
        "extensions": [
          ".ngin",
          ".nginproj",
          ".nginpkg",
          ".nginlaunch",
          ".nginsettings"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ngin",
        "scopeName": "source.ngin",
        "path": "./syntaxes/ngin.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "ngin",
        "path": "./snippets/ngin.code-snippets"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ngin",
          "title": "NGIN",
          "icon": "./media/ngin-activity.svg"
        }
      ]
    },
    "views": {
      "ngin": [
        {
          "id": "nginWorkspace",
          "name": "Workspace",
          "icon": "./media/ngin-activity.svg"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "ngin.projectEditor",
        "displayName": "NGIN Project Editor",
        "selector": [
          {
            "filenamePattern": "*.nginproj"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "ngin.selectProject",
        "title": "Select Project",
        "category": "NGIN"
      },
      {
        "command": "ngin.selectProfile",
        "title": "Select Profile",
        "category": "NGIN"
      },
      {
        "command": "ngin.build",
        "title": "Build",
        "category": "NGIN"
      },
      {
        "command": "ngin.configure",
        "title": "Configure",
        "category": "NGIN"
      },
      {
        "command": "ngin.clean",
        "title": "Clean",
        "category": "NGIN"
      },
      {
        "command": "ngin.rebuild",
        "title": "Rebuild",
        "category": "NGIN"
      },
      {
        "command": "ngin.run",
        "title": "Run",
        "category": "NGIN"
      },
      {
        "command": "ngin.debug",
        "title": "Debug",
        "category": "NGIN"
      },
      {
        "command": "ngin.validate",
        "title": "Validate",
        "category": "NGIN"
      },
      {
        "command": "ngin.analyze",
        "title": "Analyze",
        "category": "NGIN"
      },
      {
        "command": "ngin.addClangTidyAnalyzerPackage",
        "title": "Enable Clang-Tidy",
        "category": "NGIN"
      },
      {
        "command": "ngin.openClangTidyConfig",
        "title": "Open .clang-tidy",
        "category": "NGIN"
      },
      {
        "command": "ngin.createClangTidyConfig",
        "title": "Create .clang-tidy",
        "category": "NGIN"
      },
      {
        "command": "ngin.graph",
        "title": "Graph",
        "category": "NGIN"
      },
      {
        "command": "ngin.variablesExplain",
        "title": "Explain Variables",
        "category": "NGIN"
      },
      {
        "command": "ngin.settingsInit",
        "title": "Initialize Local Settings",
        "category": "NGIN"
      },
      {
        "command": "ngin.workspaceStatus",
        "title": "Workspace Status",
        "category": "NGIN"
      },
      {
        "command": "ngin.workspaceDoctor",
        "title": "Workspace Doctor",
        "category": "NGIN"
      },
      {
        "command": "ngin.openLastLaunchManifest",
        "title": "Open Last Build Manifest",
        "category": "NGIN"
      },
      {
        "command": "ngin.openProjectManifest",
        "title": "Open Project Manifest",
        "category": "NGIN"
      },
      {
        "command": "ngin.openProjectXmlSource",
        "title": "Open Project XML Source",
        "category": "NGIN"
      },
      {
        "command": "ngin.openPath",
        "title": "Open",
        "category": "NGIN"
      },
      {
        "command": "ngin.revealPath",
        "title": "Reveal in File Explorer",
        "category": "NGIN"
      },
      {
        "command": "ngin.copyPath",
        "title": "Copy Path",
        "category": "NGIN"
      },
      {
        "command": "ngin.setActiveProject",
        "title": "Set Active Project",
        "category": "NGIN"
      },
      {
        "command": "ngin.projectNewSourceFile",
        "title": "New Source File",
        "category": "NGIN"
      },
      {
        "command": "ngin.projectNewConfigFile",
        "title": "New Config File",
        "category": "NGIN"
      },
      {
        "command": "ngin.projectNewFolder",
        "title": "New Folder",
        "category": "NGIN"
      },
      {
        "command": "ngin.projectCopy",
        "title": "Copy",
        "category": "NGIN"
      },
      {
        "command": "ngin.projectDuplicate",
        "title": "Duplicate",
        "category": "NGIN"
      },
      {
        "command": "ngin.projectRename",
        "title": "Rename",
        "category": "NGIN"
      },
      {
        "command": "ngin.projectDelete",
        "title": "Delete",
        "category": "NGIN"
      },
      {
        "command": "ngin.refresh",
        "title": "Refresh",
        "category": "NGIN",
        "icon": {
          "light": "./media/refresh-light.svg",
          "dark": "./media/refresh-dark.svg"
        }
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "ngin.openPath",
          "when": "false"
        },
        {
          "command": "ngin.openProjectXmlSource",
          "when": "resourceExtname == .nginproj"
        },
        {
          "command": "ngin.revealPath",
          "when": "false"
        },
        {
          "command": "ngin.copyPath",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "ngin.refresh",
          "when": "view == nginWorkspace",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "ngin.workspaceStatus",
          "when": "view == nginWorkspace && viewItem == nginWorkspace",
          "group": "navigation@1"
        },
        {
          "command": "ngin.workspaceDoctor",
          "when": "view == nginWorkspace && viewItem == nginWorkspace",
          "group": "navigation@2"
        },
        {
          "command": "ngin.openProjectManifest",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProjectManifest)$/",
          "group": "navigation@1"
        },
        {
          "command": "ngin.openPath",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProjectSourceFile|nginProjectConfigFile|nginProjectGeneratedFile|nginProjectDependency|nginProjectInspectEntry\\.openable)$/",
          "group": "navigation@2"
        },
        {
          "command": "ngin.revealPath",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProjectManifest|nginProjectSourceFile|nginProjectSourceFolder|nginProjectConfigFile|nginProjectConfigFolder|nginProjectGeneratedFile|nginProjectGeneratedFolder|nginProjectGeneratedProfile|nginProjectDependency|nginProjectInspectEntry\\.openable)$/",
          "group": "navigation@3"
        },
        {
          "command": "ngin.copyPath",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProjectManifest|nginProjectSourceFile|nginProjectSourceFolder|nginProjectConfigFile|nginProjectConfigFolder|nginProjectGeneratedFile|nginProjectGeneratedFolder|nginProjectGeneratedProfile|nginProjectDependency|nginProjectInspectEntry\\.openable)$/",
          "group": "navigation@4"
        },
        {
          "command": "ngin.setActiveProject",
          "when": "view == nginWorkspace && viewItem == nginProject",
          "group": "navigation@5"
        },
        {
          "command": "ngin.build",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.actions@1"
        },
        {
          "command": "ngin.configure",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.actions@2"
        },
        {
          "command": "ngin.rebuild",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.actions@3"
        },
        {
          "command": "ngin.run",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.actions@4"
        },
        {
          "command": "ngin.debug",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.actions@5"
        },
        {
          "command": "ngin.validate",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@1"
        },
        {
          "command": "ngin.analyze",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@2"
        },
        {
          "command": "ngin.addClangTidyAnalyzerPackage",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@2.1"
        },
        {
          "command": "ngin.openClangTidyConfig",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@2.2"
        },
        {
          "command": "ngin.createClangTidyConfig",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@2.3"
        },
        {
          "command": "ngin.graph",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@3"
        },
        {
          "command": "ngin.variablesExplain",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@4"
        },
        {
          "command": "ngin.settingsInit",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@4"
        },
        {
          "command": "ngin.clean",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@6"
        },
        {
          "command": "ngin.projectNewSourceFile",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProjectGroup\\.source|nginProjectGroup\\.files|nginProjectSourceFolder)$/",
          "group": "ngin.new@1"
        },
        {
          "command": "ngin.projectNewConfigFile",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProject|nginProjectGroup\\.config|nginProjectGroup\\.files|nginProjectConfigFolder)$/",
          "group": "ngin.new@2"
        },
        {
          "command": "ngin.projectNewFolder",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProjectSourceFolder|nginProjectConfigFolder)$/",
          "group": "ngin.new@3"
        },
        {
          "command": "ngin.projectCopy",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProjectSourceFile|nginProjectSourceFolder|nginProjectConfigFile|nginProjectConfigFolder)$/",
          "group": "ngin.edit@1"
        },
        {
          "command": "ngin.projectDuplicate",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProjectSourceFile|nginProjectSourceFolder|nginProjectConfigFile|nginProjectConfigFolder)$/",
          "group": "ngin.edit@2"
        },
        {
          "command": "ngin.projectRename",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProjectSourceFile|nginProjectSourceFolder|nginProjectConfigFile|nginProjectConfigFolder)$/",
          "group": "ngin.edit@3"
        },
        {
          "command": "ngin.projectDelete",
          "when": "view == nginWorkspace && viewItem =~ /^(nginProjectSourceFile|nginProjectSourceFolder|nginProjectConfigFile|nginProjectConfigFolder)$/",
          "group": "ngin.edit@4"
        }
      ]
    },
    "configuration": {
      "title": "NGIN Tools",
      "properties": {
        "ngin.cli.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional explicit path to the `ngin` executable. Relative paths are resolved from the active workspace root."
        },
        "ngin.build.outputRoot": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional staged output root. When set, build output is written to `<outputRoot>/<project>/<profile>`."
        },
        "ngin.validate.onSave": {
          "type": "boolean",
          "default": false,
          "description": "Validate the current NGIN project after saving an NGIN manifest."
        },
        "ngin.analyze.onSave": {
          "type": "boolean",
          "default": false,
          "description": "Run NGIN analyzers after saving an NGIN manifest."
        },
        "ngin.cli.warnIfStale": {
          "type": "boolean",
          "default": true,
          "description": "Warn once per session if the in-repo development CLI looks older than key CLI source files."
        },
        "ngin.output.verbosity": {
          "type": "string",
          "enum": [
            "compact",
            "normal",
            "verbose"
          ],
          "default": "compact",
          "description": "Controls how much CLI and backend build output the NGIN extension writes to the Output panel."
        },
        "ngin.output.color": {
          "type": "string",
          "enum": [
            "never",
            "auto",
            "always"
          ],
          "default": "never",
          "description": "Controls ANSI color requested from the NGIN CLI in the Output panel. Use 'always' only if your VS Code build renders ANSI output correctly."
        },
        "ngin.debug.miDebuggerPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional path to the MI debugger used by `cppdbg` on Linux and macOS."
        },
        "ngin.run.terminalName": {
          "type": "string",
          "default": "NGIN",
          "description": "Integrated terminal name used for `NGIN: Run`."
        },
        "ngin.cpp.configurationProvider.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Register NGIN as a C/C++ custom configuration provider for the current workspace when compile commands are available."
        },
        "ngin.ui.statusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the NGIN workspace, project, profile, build, run, and debug items in the bottom status bar."
        }
      }
    },
    "taskDefinitions": [
      {
        "type": "ngin",
        "required": [
          "command"
        ],
        "properties": {
          "command": {
            "type": "string",
            "enum": [
              "configure",
              "build",
              "clean",
              "rebuild",
              "validate",
              "analyze",
              "graph",
              "workspaceStatus",
              "workspaceDoctor"
            ]
          },
          "project": {
            "type": "string"
          },
          "profile": {
            "type": "string"
          },
          "output": {
            "type": "string"
          }
        }
      }
    ],
    "problemMatchers": [
      {
        "name": "ngin-file",
        "label": "NGIN File Errors",
        "owner": "ngin",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^(?:\\s*-\\s+)?((?:[A-Za-z]:)?[^:]+\\.(?:ngin|nginproj|nginpkg|nginlaunch|nginsettings|xml|cfg)):\\s+(.+)$",
          "file": 1,
          "message": 2
        }
      }
    ],
    "debuggers": [
      {
        "type": "ngin",
        "label": "NGIN",
        "configurationAttributes": {
          "launch": {
            "required": [
              "project",
              "profile"
            ],
            "properties": {
              "project": {
                "type": "string",
                "description": "Path to the .nginproj file."
              },
              "profile": {
                "type": "string",
                "description": "Project profile to build and debug."
              },
              "cliPath": {
                "type": "string",
                "description": "Optional explicit path to the ngin executable."
              },
              "outputDir": {
                "type": "string",
                "description": "Optional explicit staged output directory."
              },
              "programArgs": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "env": {
                "type": "object",
                "default": {}
              },
              "preBuild": {
                "type": "boolean",
                "default": false,
                "description": "When true, always run `ngin build` before launching. Otherwise reuse the generated launch manifest when available and build only if needed."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "ngin",
            "request": "launch",
            "name": "NGIN: Debug Hello.Hosted",
            "project": "Examples/Hello.Hosted/Hello.Hosted.nginproj",
            "profile": "Debug",
            "preBuild": false,
            "programArgs": [],
            "env": {}
          }
        ]
      }
    ]
  }
}
