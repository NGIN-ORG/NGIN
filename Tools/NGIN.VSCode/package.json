{
  "name": "ngin-tools",
  "displayName": "NGIN Tools",
  "description": "CLI-first build, run, and debug workflows for NGIN projects in VS Code.",
  "version": "0.1.0",
  "publisher": "ngin",
  "license": "UNLICENSED",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/NGIN-ORG/NGIN.git",
    "directory": "Tools/NGIN.VSCode"
  },
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Debuggers"
  ],
  "activationEvents": [
    "onDebugResolve:ngin",
    "workspaceContains:**/*.nginproj",
    "workspaceContains:**/*.nginsettings"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "watch": "node ./scripts/build.mjs --watch",
    "typecheck": "tsc -p ./tsconfig.json --noEmit && tsc -p ./tsconfig.tests.json --noEmit",
    "test:unit": "tsc -p ./tsconfig.tests.json && node --test ./dist-test/test/unit/*.test.js",
    "test:integration": "tsc -p ./tsconfig.tests.json && node ./dist-test/test/integration/runTest.js",
    "test": "npm run test:unit && npm run test:integration"
  },
  "dependencies": {
    "fast-xml-parser": "^5.2.5",
    "vscode-cpptools": "^7.1.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.17",
    "@types/vscode": "^1.86.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.1",
    "mocha": "^11.1.0",
    "typescript": "^5.8.2"
  },
  "contributes": {
    "languages": [
      {
        "id": "ngin",
        "aliases": [
          "NGIN"
        ],
        "extensions": [
          ".ngin",
          ".nginproj",
          ".nginpkg",
          ".nginlaunch",
          ".nginsettings"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ngin",
        "scopeName": "source.ngin",
        "path": "./syntaxes/ngin.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "ngin",
        "path": "./snippets/ngin.code-snippets"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ngin",
          "title": "NGIN",
          "icon": "./media/ngin-activity.svg"
        }
      ]
    },
    "views": {
      "ngin": [
        {
          "id": "nginOverview",
          "name": "Overview",
          "icon": "./media/ngin-activity.svg"
        },
        {
          "id": "nginProjects",
          "name": "Projects",
          "icon": "./media/ngin-activity.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "ngin.selectProject",
        "title": "Select Project",
        "category": "NGIN"
      },
      {
        "command": "ngin.selectProfile",
        "title": "Select Profile",
        "category": "NGIN"
      },
      {
        "command": "ngin.build",
        "title": "Build",
        "category": "NGIN"
      },
      {
        "command": "ngin.configure",
        "title": "Configure",
        "category": "NGIN"
      },
      {
        "command": "ngin.clean",
        "title": "Clean",
        "category": "NGIN"
      },
      {
        "command": "ngin.rebuild",
        "title": "Rebuild",
        "category": "NGIN"
      },
      {
        "command": "ngin.run",
        "title": "Run",
        "category": "NGIN"
      },
      {
        "command": "ngin.debug",
        "title": "Debug",
        "category": "NGIN"
      },
      {
        "command": "ngin.validate",
        "title": "Validate",
        "category": "NGIN"
      },
      {
        "command": "ngin.graph",
        "title": "Graph",
        "category": "NGIN"
      },
      {
        "command": "ngin.variablesExplain",
        "title": "Explain Variables",
        "category": "NGIN"
      },
      {
        "command": "ngin.settingsInit",
        "title": "Initialize Local Settings",
        "category": "NGIN"
      },
      {
        "command": "ngin.metagen",
        "title": "Generate Metadata",
        "category": "NGIN"
      },
      {
        "command": "ngin.workspaceStatus",
        "title": "Workspace Status",
        "category": "NGIN"
      },
      {
        "command": "ngin.workspaceDoctor",
        "title": "Workspace Doctor",
        "category": "NGIN"
      },
      {
        "command": "ngin.openLastLaunchManifest",
        "title": "Open Last Build Manifest",
        "category": "NGIN"
      },
      {
        "command": "ngin.openProjectManifest",
        "title": "Open Project Manifest",
        "category": "NGIN"
      },
      {
        "command": "ngin.setActiveProject",
        "title": "Set Active Project",
        "category": "NGIN"
      },
      {
        "command": "ngin.projectNewSourceFile",
        "title": "New Source File",
        "category": "NGIN"
      },
      {
        "command": "ngin.projectNewConfigFile",
        "title": "New Config File",
        "category": "NGIN"
      },
      {
        "command": "ngin.projectNewFolder",
        "title": "New Folder",
        "category": "NGIN"
      },
      {
        "command": "ngin.projectCopy",
        "title": "Copy",
        "category": "NGIN"
      },
      {
        "command": "ngin.projectDuplicate",
        "title": "Duplicate",
        "category": "NGIN"
      },
      {
        "command": "ngin.projectRename",
        "title": "Rename",
        "category": "NGIN"
      },
      {
        "command": "ngin.projectDelete",
        "title": "Delete",
        "category": "NGIN"
      },
      {
        "command": "ngin.refresh",
        "title": "Refresh",
        "category": "NGIN",
        "icon": {
          "light": "./media/refresh-light.svg",
          "dark": "./media/refresh-dark.svg"
        }
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ngin.refresh",
          "when": "view == nginOverview",
          "group": "navigation"
        },
        {
          "command": "ngin.refresh",
          "when": "view == nginProjects",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "ngin.workspaceStatus",
          "when": "view == nginProjects && viewItem == nginWorkspace",
          "group": "navigation@1"
        },
        {
          "command": "ngin.workspaceDoctor",
          "when": "view == nginProjects && viewItem == nginWorkspace",
          "group": "navigation@2"
        },
        {
          "command": "ngin.openProjectManifest",
          "when": "view == nginProjects && viewItem =~ /^(nginProject|nginProjectManifest)$/",
          "group": "navigation@1"
        },
        {
          "command": "ngin.setActiveProject",
          "when": "view == nginProjects && viewItem == nginProject",
          "group": "navigation@2"
        },
        {
          "command": "ngin.build",
          "when": "view == nginProjects && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.actions@1"
        },
        {
          "command": "ngin.configure",
          "when": "view == nginProjects && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.actions@2"
        },
        {
          "command": "ngin.rebuild",
          "when": "view == nginProjects && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.actions@3"
        },
        {
          "command": "ngin.run",
          "when": "view == nginProjects && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.actions@4"
        },
        {
          "command": "ngin.debug",
          "when": "view == nginProjects && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.actions@5"
        },
        {
          "command": "ngin.validate",
          "when": "view == nginProjects && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@1"
        },
        {
          "command": "ngin.graph",
          "when": "view == nginProjects && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@2"
        },
        {
          "command": "ngin.variablesExplain",
          "when": "view == nginProjects && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@3"
        },
        {
          "command": "ngin.settingsInit",
          "when": "view == nginProjects && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@4"
        },
        {
          "command": "ngin.metagen",
          "when": "view == nginProjects && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@5"
        },
        {
          "command": "ngin.clean",
          "when": "view == nginProjects && viewItem =~ /^(nginProject|nginProfile)$/",
          "group": "ngin.inspect@6"
        },
        {
          "command": "ngin.projectNewSourceFile",
          "when": "view == nginProjects && viewItem =~ /^(nginProject|nginProjectSourceFolder)$/",
          "group": "ngin.new@1"
        },
        {
          "command": "ngin.projectNewConfigFile",
          "when": "view == nginProjects && viewItem =~ /^(nginProject|nginProjectConfigFolder)$/",
          "group": "ngin.new@2"
        },
        {
          "command": "ngin.projectNewFolder",
          "when": "view == nginProjects && viewItem =~ /^(nginProjectSourceFolder|nginProjectConfigFolder)$/",
          "group": "ngin.new@3"
        },
        {
          "command": "ngin.projectCopy",
          "when": "view == nginProjects && viewItem =~ /^(nginProjectSourceFile|nginProjectSourceFolder|nginProjectConfigFile|nginProjectConfigFolder)$/",
          "group": "ngin.edit@1"
        },
        {
          "command": "ngin.projectDuplicate",
          "when": "view == nginProjects && viewItem =~ /^(nginProjectSourceFile|nginProjectSourceFolder|nginProjectConfigFile|nginProjectConfigFolder)$/",
          "group": "ngin.edit@2"
        },
        {
          "command": "ngin.projectRename",
          "when": "view == nginProjects && viewItem =~ /^(nginProjectSourceFile|nginProjectSourceFolder|nginProjectConfigFile|nginProjectConfigFolder)$/",
          "group": "ngin.edit@3"
        },
        {
          "command": "ngin.projectDelete",
          "when": "view == nginProjects && viewItem =~ /^(nginProjectSourceFile|nginProjectSourceFolder|nginProjectConfigFile|nginProjectConfigFolder)$/",
          "group": "ngin.edit@4"
        }
      ]
    },
    "configuration": {
      "title": "NGIN Tools",
      "properties": {
        "ngin.cli.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional explicit path to the `ngin` executable. Relative paths are resolved from the active workspace root."
        },
        "ngin.build.outputRoot": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional staged output root. When set, build output is written to `<outputRoot>/<project>/<profile>`."
        },
        "ngin.validate.onSave": {
          "type": "boolean",
          "default": false,
          "description": "Validate the current NGIN project after saving an NGIN manifest."
        },
        "ngin.cli.warnIfStale": {
          "type": "boolean",
          "default": true,
          "description": "Warn once per session if the in-repo development CLI looks older than key CLI source files."
        },
        "ngin.debug.miDebuggerPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional path to the MI debugger used by `cppdbg` on Linux and macOS."
        },
        "ngin.run.terminalName": {
          "type": "string",
          "default": "NGIN",
          "description": "Integrated terminal name used for `NGIN: Run`."
        },
        "ngin.cpp.configurationProvider.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Register NGIN as a C/C++ custom configuration provider for the current workspace when compile commands are available."
        },
        "ngin.ui.statusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the NGIN workspace, project, profile, build, run, and debug items in the bottom status bar."
        }
      }
    },
    "taskDefinitions": [
      {
        "type": "ngin",
        "required": [
          "command"
        ],
        "properties": {
          "command": {
            "type": "string",
            "enum": [
              "configure",
              "build",
              "clean",
              "rebuild",
              "validate",
              "graph",
              "workspaceStatus",
              "workspaceDoctor"
            ]
          },
          "project": {
            "type": "string"
          },
          "profile": {
            "type": "string"
          },
          "output": {
            "type": "string"
          }
        }
      }
    ],
    "problemMatchers": [
      {
        "name": "ngin-file",
        "label": "NGIN File Errors",
        "owner": "ngin",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^(?:\\s*-\\s+)?((?:[A-Za-z]:)?[^:]+\\.(?:ngin|nginproj|nginpkg|nginlaunch|nginsettings|xml|cfg)):\\s+(.+)$",
          "file": 1,
          "message": 2
        }
      }
    ],
    "debuggers": [
      {
        "type": "ngin",
        "label": "NGIN",
        "configurationAttributes": {
          "launch": {
            "required": [
              "project",
              "profile"
            ],
            "properties": {
              "project": {
                "type": "string",
                "description": "Path to the .nginproj file."
              },
              "profile": {
                "type": "string",
                "description": "Project profile to build and debug."
              },
              "cliPath": {
                "type": "string",
                "description": "Optional explicit path to the ngin executable."
              },
              "outputDir": {
                "type": "string",
                "description": "Optional explicit staged output directory."
              },
              "programArgs": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "env": {
                "type": "object",
                "default": {}
              },
              "preBuild": {
                "type": "boolean",
                "default": false,
                "description": "When true, always run `ngin build` before launching. Otherwise reuse the generated launch manifest when available and build only if needed."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "ngin",
            "request": "launch",
            "name": "NGIN: Debug App.Basic [Runtime]",
            "project": "Examples/App.Basic/App.Basic.nginproj",
            "profile": "Runtime",
            "preBuild": false,
            "programArgs": [],
            "env": {}
          }
        ]
      }
    ]
  }
}
