{
  "name": "ngin-tools",
  "displayName": "NGIN Tools",
  "description": "CLI-first build, run, and debug workflows for NGIN projects in VS Code.",
  "version": "0.1.0",
  "publisher": "ngin",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Other",
    "Programming Languages",
    "Debuggers"
  ],
  "activationEvents": [
    "onDebugResolve:ngin",
    "onView:nginOverview",
    "onView:nginProjects",
    "workspaceContains:**/*.nginproj"
  ],
  "main": "./dist/extension.js",
  "scripts": {
    "build": "node ./scripts/build.mjs",
    "watch": "node ./scripts/build.mjs --watch",
    "typecheck": "tsc -p ./tsconfig.json --noEmit && tsc -p ./tsconfig.tests.json --noEmit",
    "test:unit": "tsc -p ./tsconfig.tests.json && node --test ./dist-test/test/unit/*.test.js",
    "test:integration": "tsc -p ./tsconfig.tests.json && node ./dist-test/test/integration/runTest.js",
    "test": "npm run test:unit && npm run test:integration"
  },
  "dependencies": {
    "fast-xml-parser": "^5.2.5",
    "vscode-cpptools": "^7.1.1"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.86.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.25.1",
    "mocha": "^11.1.0",
    "typescript": "^5.8.2"
  },
  "contributes": {
    "languages": [
      {
        "id": "ngin",
        "aliases": [
          "NGIN"
        ],
        "extensions": [
          ".ngin",
          ".nginproj",
          ".nginpkg",
          ".ngintarget"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ngin",
        "scopeName": "source.ngin",
        "path": "./syntaxes/ngin.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "ngin",
        "path": "./snippets/ngin.code-snippets"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ngin",
          "title": "NGIN",
          "icon": "./media/ngin-activity.svg"
        }
      ]
    },
    "views": {
      "ngin": [
        {
          "id": "nginOverview",
          "name": "Overview"
        },
        {
          "id": "nginProjects",
          "name": "Projects"
        }
      ]
    },
    "commands": [
      {
        "command": "ngin.selectProject",
        "title": "Select Project",
        "category": "NGIN"
      },
      {
        "command": "ngin.selectVariant",
        "title": "Select Variant",
        "category": "NGIN"
      },
      {
        "command": "ngin.selectConfiguration",
        "title": "Select Configuration",
        "category": "NGIN"
      },
      {
        "command": "ngin.build",
        "title": "Build",
        "category": "NGIN"
      },
      {
        "command": "ngin.run",
        "title": "Run",
        "category": "NGIN"
      },
      {
        "command": "ngin.debug",
        "title": "Debug",
        "category": "NGIN"
      },
      {
        "command": "ngin.validate",
        "title": "Validate",
        "category": "NGIN"
      },
      {
        "command": "ngin.graph",
        "title": "Graph",
        "category": "NGIN"
      },
      {
        "command": "ngin.workspaceStatus",
        "title": "Workspace Status",
        "category": "NGIN"
      },
      {
        "command": "ngin.workspaceDoctor",
        "title": "Workspace Doctor",
        "category": "NGIN"
      },
      {
        "command": "ngin.openLastTargetManifest",
        "title": "Open Last Target Manifest",
        "category": "NGIN"
      },
      {
        "command": "ngin.refresh",
        "title": "Refresh",
        "category": "NGIN",
        "icon": {
          "light": "./media/refresh-light.svg",
          "dark": "./media/refresh-dark.svg"
        }
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "ngin.refresh",
          "when": "view == nginOverview",
          "group": "navigation"
        },
        {
          "command": "ngin.refresh",
          "when": "view == nginProjects",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "ngin.build",
          "when": "view == nginProjects && viewItem == nginVariant",
          "group": "inline"
        },
        {
          "command": "ngin.run",
          "when": "view == nginProjects && viewItem == nginVariant",
          "group": "inline"
        },
        {
          "command": "ngin.debug",
          "when": "view == nginProjects && viewItem == nginVariant",
          "group": "inline"
        },
        {
          "command": "ngin.validate",
          "when": "view == nginProjects && viewItem == nginVariant",
          "group": "navigation"
        },
        {
          "command": "ngin.graph",
          "when": "view == nginProjects && viewItem == nginVariant",
          "group": "navigation"
        }
      ]
    },
    "configuration": {
      "title": "NGIN Tools",
      "properties": {
        "ngin.cli.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional explicit path to the `ngin` executable. Relative paths are resolved from the active workspace root."
        },
        "ngin.build.outputRoot": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional staged output root. When set, build output is written to `<outputRoot>/<project>/<variant>/<configuration>`."
        },
        "ngin.validate.onSave": {
          "type": "boolean",
          "default": false,
          "description": "Validate the current NGIN project after saving an NGIN manifest."
        },
        "ngin.cli.warnIfStale": {
          "type": "boolean",
          "default": true,
          "description": "Warn once per session if the in-repo development CLI looks older than key CLI source files."
        },
        "ngin.debug.miDebuggerPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional path to the MI debugger used by `cppdbg` on Linux and macOS."
        },
        "ngin.run.terminalName": {
          "type": "string",
          "default": "NGIN",
          "description": "Integrated terminal name used for `NGIN: Run`."
        },
        "ngin.cpp.configurationProvider.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Register NGIN as a C/C++ custom configuration provider for the current workspace when compile commands are available."
        },
        "ngin.ui.statusBar.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show the NGIN workspace, project, variant, configuration, build, run, and debug items in the bottom status bar."
        }
      }
    },
    "taskDefinitions": [
      {
        "type": "ngin",
        "required": [
          "command"
        ],
        "properties": {
          "command": {
            "type": "string",
            "enum": [
              "build",
              "validate",
              "graph",
              "workspaceStatus",
              "workspaceDoctor"
            ]
          },
          "project": {
            "type": "string"
          },
          "variant": {
            "type": "string"
          },
          "configuration": {
            "type": "string"
          },
          "output": {
            "type": "string"
          }
        }
      }
    ],
    "problemMatchers": [
      {
        "name": "ngin-file",
        "label": "NGIN File Errors",
        "owner": "ngin",
        "fileLocation": "absolute",
        "pattern": {
          "regexp": "^(?:\\s*-\\s+)?((?:[A-Za-z]:)?[^:]+\\.(?:ngin|nginproj|nginpkg|ngintarget|xml|cfg)):\\s+(.+)$",
          "file": 1,
          "message": 2
        }
      }
    ],
    "debuggers": [
      {
        "type": "ngin",
        "label": "NGIN",
        "configurationAttributes": {
          "launch": {
            "required": [
              "project",
              "variant"
            ],
            "properties": {
              "project": {
                "type": "string",
                "description": "Path to the .nginproj file."
              },
              "variant": {
                "type": "string",
                "description": "Variant name to build and debug."
              },
              "configuration": {
                "type": "string",
                "description": "Build configuration to use for staging and debugging, such as Debug or Release."
              },
              "cliPath": {
                "type": "string",
                "description": "Optional explicit path to the ngin executable."
              },
              "outputDir": {
                "type": "string",
                "description": "Optional explicit staged output directory."
              },
              "programArgs": {
                "type": "array",
                "items": {
                  "type": "string"
                },
                "default": []
              },
              "env": {
                "type": "object",
                "default": {}
              },
              "preBuild": {
                "type": "boolean",
                "default": false,
                "description": "When true, always run `ngin project build` before launching. Otherwise reuse the staged target when available and build only if needed."
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "ngin",
            "request": "launch",
            "name": "NGIN: Debug App.Basic [Runtime]",
            "project": "Examples/App.Basic/App.Basic.nginproj",
            "variant": "Runtime",
            "configuration": "Debug",
            "preBuild": false,
            "programArgs": [],
            "env": {}
          }
        ]
      }
    ]
  }
}
